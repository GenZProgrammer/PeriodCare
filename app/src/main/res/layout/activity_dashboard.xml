<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF5F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Judul -->
        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Halo, Pengguna 🌸"
            android:textColor="#C2185B"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pantau siklus menstruasi Anda dengan mudah"
            android:textColor="#880E4F"
            android:textSize="15sp"
            android:layout_marginBottom="20dp"/>

        <!-- HPHT -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Hari Pertama Haid Terakhir">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="true"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Siklus -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Siklus Menstruasi (Hari)">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCycle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Tombol Hitung -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCalculate"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="20dp"
            android:text="Hitung Siklus"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="#EC407A"/>

        <!-- Kalender -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <com.prolificinteractive.materialcalendarview.MaterialCalendarView
                android:id="@+id/calendarView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                app:mcv_selectionColor="#EC407A"
                app:mcv_showOtherDates="all"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- Judul -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hasil Analisis"
            android:textColor="#C2185B"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"/>

        <!-- ================= HAID ================= -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMenstruation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="15dp"
            app:cardElevation="4dp">

            <TextView
                android:id="@+id/tvMenstruation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:text="🔴 Estimasi Haid"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#D81B60"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- ================= MASA SUBUR ================= -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFertile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="15dp"
            app:cardElevation="4dp">

            <TextView
                android:id="@+id/tvFertile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:text="🟢 Masa Subur"
                android:textColor="#43A047"
                android:textStyle="bold"
                android:textSize="16sp"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- ================= OVULASI ================= -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardOvulation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="15dp"
            app:cardElevation="4dp">

            <TextView
                android:id="@+id/tvOvulation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:text="🟣 Hari Ovulasi"
                android:textColor="#7E57C2"
                android:textStyle="bold"
                android:textSize="16sp"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- ================= HPL ================= -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHpl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="15dp"
            app:cardElevation="4dp">

            <TextView
                android:id="@+id/tvHpl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:text="👶 Estimasi HPL"
                android:textColor="#00897B"
                android:textStyle="bold"
                android:textSize="16sp"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- Logout -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginBottom="30dp"
            android:text="Logout"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="#E53935"/>

    </LinearLayout>

</ScrollView>